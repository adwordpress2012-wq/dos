# =====================================================================
# Directive OS — environment variables (placeholders only)
# Copy this file to .env.local (gitignored) and fill in real values.
# Never commit real secrets.
# =====================================================================

# ----- Database -----
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DATABASE_MODE=production

# ----- Vercel runtime -----
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
BASE_PATH=/

# Vercel injects this automatically in production deploys.
# Leave blank locally; set only if running an OIDC-authenticated workflow.
VERCEL_OIDC_TOKEN=

# ----- OpenAI -----
OPENAI_API_KEY=sk-proj-replace-with-real-key

# ----- Twilio (voice + SMS) -----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-with-real-token
TWILIO_FROM_NUMBER=+61400000000

# ----- Stripe -----
# Use sk_test_ in dev/staging, sk_live_ in production.
STRIPE_KEY_ACTIVE=sk_test_replace_with_real_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_real_value
STRIPE_PRICE_ONBOARDING=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_SUBSCRIPTION=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_PER_SEAT=price_xxxxxxxxxxxxxxxx
STRIPE_PRICE_EXCESS_USAGE=price_xxxxxxxxxxxxxxxx
ONBOARDING_PRICE_ID=price_xxxxxxxxxxxxxxxx
SUBSCRIPTION_PRICE_ID=price_xxxxxxxxxxxxxxxx

# ----- Resend (transactional email) -----
RESEND_API_KEY=re_replace_with_real_key
DOS_RESEND_KEY=re_replace_with_real_key
DOS_RESEND_CFG=

# ----- Internal API auth between services -----
# Used by Sarah/Micah voice + chat handlers to talk to the API server.
# Any one of the *_API_KEY aliases below is checked at runtime.
DOS_API_KEY=replace-with-shared-secret
MICAH_API_KEY=replace-with-shared-secret
MICAH_DOS_API_KEY=replace-with-shared-secret
DOS_MICAH_API_KEY=replace-with-shared-secret
CLIENT_JWT_SECRET=replace-with-jwt-signing-secret

# ----- Admin login (legacy basic auth on /admin) -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password

# ----- BookOS -----
BOOKOS_VOICE_WEBHOOK_URL=https://your-bookos-domain.com/api/voice/inbound
BOOKOS_DOMAIN=https://bookos.example.com

# ----- Expo / mobile app (client-side, safe to expose to the bundle) -----
EXPO_PUBLIC_API_URL=https://api.directiveos.com.au
EXPO_PUBLIC_DOMAIN=directiveos.com.au
EXPO_PUBLIC_REPL_ID=

# ----- Replit-specific (optional, only if running inside Replit) -----
REPL_ID=
REPLIT_DEV_DOMAIN=
REPLIT_INTERNAL_APP_DOMAIN=
